              '  }\n'
              '\n'
              '  // ── 加载验证码设置 ─────────────────────────────────────────────────────────\n'
              '\n'
              '  Future<void> _loadVerificationSettings() async {\n'
              '    try {\n'
              '      final dio = ref.read(dioProvider);\n'
              '      final resp = await dio.get<Map<String, dynamic>>(\n'
              '        \'/api/platform/v1/auth/verification/settings\',\n'
              '      );\n'
              '      final data = resp.data?[\'data\'] as Map<String, dynamic>?;\n'
              '      if (!mounted || data == null) return;\n'
              '      final smsEnabled = data[\'smsEnabled\'] as bool? ?? true;\n'
              '      final emailEnabled = data[\'emailEnabled\'] as bool? ?? true;\n'
              '      _IdMode mode = _idMode;\n'
              '      if (_idMode == _IdMode.mobile && !smsEnabled && emailEnabled) {\n'
              '        mode = _IdMode.email;\n'
              '      } else if (_idMode == _IdMode.email && !emailEnabled && smsEnabled) {\n'
              '        mode = _IdMode.mobile;\n'
              '      }\n'
              '      setState(() {\n'
              '        _settingsData = data;\n'
              '        _smsEnabled = smsEnabled;\n'
              '        _emailEnabled = emailEnabled;\n'
              '        _idMode = mode;\n'
              '      });\n'
              '      _refreshVerificationRequired();\n'
              '    } catch (_) {}\n'
              '  }\n'
              '\n'
              '  void _refreshVerificationRequired() {\n'
              '    if (_settingsData == null) return;\n'
              '    final required = _idMode == _IdMode.mobile\n'
              '        ? _settingsData![\'smsRequired\'] as bool? ?? false\n'
              '        : _settingsData![\'emailRequired\'] as bool? ?? false;\n'
              '    setState(() => _verificationRequired = required);\n'
              '  }\n'
              '\n'
              '  // ── 发送验证码 ─────────────────────────────────────────────────────────────\n'
              '\n'
              '  Future<void> _sendCode() async {\n'
              '    final identifier = _identifierCtrl.text.trim();\n'
              '    if (_idMode == _IdMode.mobile) {\n'
              '      final err = Validators.validateMobile(identifier);\n'
              '      if (err != null) {\n'
              '        _showError(err);\n'
              '        return;\n'
              '      }\n'
              '    } else {\n'
              '      final err = Validators.validateEmail(identifier);\n'
              '      if (err != null) {\n'
              '        _showError(err);\n'
              '        return;\n'
              '      }\n'
              '    }\n'
              '    try {\n'
              '      final dio = ref.read(dioProvider);\n'
              '      await dio.post(\'/api/platform/v1/auth/verification/send\', data: {\n'
              '        \'identifier\': identifier,\n'
              '        \'channel\': _idMode == _IdMode.mobile ? \'sms\' : \'email\',\n'
              '        \'purpose\': \'register\',\n'
              '      });\n'
              '      _startCountdown();\n'
              '    } on DioException catch (e) {\n'
              '      final err = ErrorHandler.fromDioException(e);\n'
              '      _showError(err is ServerError ? err.message : \'发送失败，请重试\');\n'
              '    }\n'
              '  }\n'
              '\n'
              '  void _startCountdown() {\n'
              '    setState(() => _countdown = 60);\n'
              '    _countdownTimer = Timer.periodic(const Duration(seconds: 1), (t) {\n'
              '      if (_countdown <= 1) {\n'
              '        t.cancel();\n'
              '        if (mounted) setState(() => _countdown = 0);\n'
              '      } else {\n'
              '        if (mounted) setState(() => _countdown--);\n'
              '      }\n'
              '    });\n'
              '  }\n'
              '\n'
              '  // ── 图形验证码 ─────────────────────────────────────────────────────────────\n'
              '\n'
              '  Future<bool> _checkAndHandleCaptcha() async {\n'
              '    try {\n'
              '      final dio = ref.read(dioProvider);\n'
              '      final checkResp = await dio.get<Map<String, dynamic>>(\n'
              '        \'/api/client/v1/auth/captcha/check\',\n'
              '      );\n'
              '      final required =\n'
              '          checkResp.data?[\'data\']?[\'captchaRequired\'] as bool? ?? false;\n'
              '      if (!required) return true;\n'
              '\n'
              '      final genResp = await dio.post<Map<String, dynamic>>(\n'
              '        \'/api/client/v1/auth/captcha/generate\',\n'
              '      );\n'
              '      final token = genResp.data?[\'data\']?[\'token\'] as String?;\n'
              '      final question = genResp.data?[\'data\']?[\'question\'] as String?;\n'
              '      if (token == null || question == null) return true;\n'
              '\n'
              '      _captchaToken = token;\n'
              '      _captchaAnswerCtrl.clear();\n'
              '      if (!mounted) return false;\n'
              '      final answer = await _showCaptchaDialog(question);\n'
              '      if (answer == null || answer.isEmpty) return false;\n'
              '      _captchaAnswerCtrl.text = answer;\n'
              '      return true;\n'
              '    } catch (_) {\n'
              '      return true;\n'
              '    }\n'
              '  }\n'
              '\n'
              '  Future<String?> _showCaptchaDialog(String question) {\n'
              '    return showDialog<String>(\n'
              '      context: context,\n'
              '      barrierDismissible: false,\n'
              '      builder: (ctx) => AlertDialog(\n'
              '        shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(16)),\n'
              '        title: const Text(\'图形验证码\',\n'
              '            style: TextStyle(fontSize: 17, fontWeight: FontWeight.w600)),\n'
              '        content: Column(mainAxisSize: MainAxisSize.min, children: [\n'
              '          Container(\n'
              '            padding: const EdgeInsets.all(16),\n'
              '            decoration: BoxDecoration(\n'
              '                color: _tagBg, borderRadius: BorderRadius.circular(8)),\n'
              '            child: Text(question,\n'
              '                style: const TextStyle(\n'
              '                    fontSize: 24,\n'
              '                    fontWeight: FontWeight.w700,\n'
              '                    letterSpacing: 4),\n'
              '                textAlign: TextAlign.center),\n'
              '          ),\n'
              '          const SizedBox(height: 12),\n'
              '          TextField(\n'
              '            controller: _captchaAnswerCtrl,\n'
              '            autofocus: true,\n'
              '            keyboardType: TextInputType.number,\n'
              '            decoration: InputDecoration(\n'
              '              hintText: \'请输入答案\',\n'
              '              border:\n'
              '                  OutlineInputBorder(borderRadius: BorderRadius.circular(8)),\n'
              '            ),\n'
              '          ),\n'
              '        ]),\n'
              '        actions: [\n'
              '          TextButton(\n'
              '            onPressed: () => Navigator.pop(ctx),\n'
              '            child: const Text(\'取消\', style: TextStyle(color: _txtGray)),\n'
              '          ),\n'
              '          TextButton(\n'
              '            onPressed: () => Navigator.pop(ctx, _captchaAnswerCtrl.text.trim()),\n'
              '            child: const Text(\'确认\', style: TextStyle(color: _primary)),\n'
              '          ),\n'
              '        ],\n'
              '      ),\n'
              '    );\n'
              '  }\n'
              '\n'
              '  // ── 注册逻辑 ───────────────────────────────────────────────────────────────\n'
              '\n'
              '  Future<void> _register() async {\n'
              '    if (!_agreedToTerms || _isLoading) return;\n'
              '\n'
              '    final displayName = _displayNameCtrl.text.trim();\n'
              '    final identifier = _identifierCtrl.text.trim();\n'
              '    final password = _passwordCtrl.text;\n'
              '    final confirm = _confirmCtrl.text;\n'
              '    final joinCredential = _enterpriseCtrl.text.trim(); // 企业码或邀请码\n'
              '    final isInvitationCode = _isInvitationCode(joinCredential);\n'
              '\n'
              '    // 基础校验\n'
              '    if (displayName.isEmpty) {\n'
              '      _showError(\'请输入昵称\');\n'
              '      return;\n'
              '    }\n'
              '\n'
              '    if (identifier.isEmpty) {\n'
              '      _showError(_idMode == _IdMode.mobile ? \'请输入手机号\' : \'请输入邮箱\');\n'
              '      return;\n'
              '    }\n'
              '    if (_idMode == _IdMode.mobile) {\n'
              '      final err = Validators.validateMobile(identifier);\n'
              '      if (err != null) {\n'
              '        _showError(err);\n'
              '        return;\n'
              '      }\n'
              '    } else {\n'
              '      final err = Validators.validateEmail(identifier);\n'
              '      if (err != null) {\n'
              '        _showError(err);\n'
              '        return;\n'
              '      }\n'
              '    }\n'
              '    if (password.length < 6) {\n'
              '      _showError(\'密码至少6位\');\n'
              '      return;\n'
              '    }\n'
              '    if (password != confirm) {\n'
              '      _showError(\'两次密码不一致\');\n'
              '      return;\n'
              '    }\n'
              '    if (_verificationRequired && _codeCtrl.text.trim().isEmpty) {\n'
              '      _showError(\'请先获取并填写验证码\');\n'
              '      return;\n'
              '    }\n'
              '\n'
              '    setState(() => _isLoading = true);\n'
              '    try {\n'
              '      final canProceed = await _checkAndHandleCaptcha();\n'
              '      if (!canProceed) {\n'
              '        setState(() => _isLoading = false);\n'
              '        return;\n'
              '      }\n'
              '\n'
              '      final captchaAnswer = _captchaAnswerCtrl.text.trim();\n'
              '      final notifier = ref.read(authProvider.notifier);\n'
              '\n'
              '      if (joinCredential.isNotEmpty && !isInvitationCode) {\n'
              '        // 企业注册：填了企业码，用搜索到的 tenantId（或直接用输入值）\n'
              '        final tenantIdOrCode = _foundTenantId ?? joinCredential;\n'
              '        await notifier.registerEnterprise(\n'
              '          tenantIdOrCode: tenantIdOrCode,\n'
              '          password: password,\n'
              '          displayName: displayName,\n'
              '          loginType: _currentLoginType(),\n'
              '          email: _idMode == _IdMode.email ? identifier : null,\n'
              '          mobile: _idMode == _IdMode.mobile ? identifier : null,\n'
              '          verificationCode:\n'
              '              _verificationRequired ? _codeCtrl.text.trim() : null,\n'
              '          captchaToken: _captchaToken,\n'
              '          captchaAnswer: captchaAnswer.isNotEmpty ? captchaAnswer : null,\n'
              '        );\n'
              '      } else {\n'
              '        // 平台注册：未填企业码，或填的是邀请码。\n'
              '        await notifier.registerPlatform(\n'
              '          displayName: displayName,\n'
              '          password: password,\n'
              '          loginType: _currentLoginType(),\n'
              '          mobile: _idMode == _IdMode.mobile ? identifier : null,\n'
              '          email: _idMode == _IdMode.email ? identifier : null,\n'
              '          verificationCode:\n'
              '              _verificationRequired ? _codeCtrl.text.trim() : null,\n'
              '          captchaToken: _captchaToken,\n'
              '          captchaAnswer: captchaAnswer.isNotEmpty ? captchaAnswer : null,\n'
              '          invitationCode: isInvitationCode ? joinCredential : null,\n'
              '        );\n'
              '      }\n'
              '      // 注册+登录成功，router 自动跳转\n'
              '    } catch (e) {\n'
              '      if (!mounted) return;\n'
              '      String msg = \'注册失败，请重试\';\n'
              '      if (e is DioException) {\n'
              '        final err = ErrorHandler.fromDioException(e);\n'
              '        if (err is ServerError) {\n'
              '          if (err.code == \'AUTH_CAPTCHA_REQUIRED\') {\n'
              '            setState(() => _isLoading = false);\n'
              '            final ok = await _checkAndHandleCaptcha();\n'
              '            if (ok) _register();\n'
              '            return;\n'
              '          }\n'
              '          if (err.code == \'AUTH_VERIFICATION_REQUIRED\') {\n'
              '            setState(() => _verificationRequired = true);\n'
              '            msg = \'请先获取并填写验证码\';\n'
              '          } else {\n'
              '            msg = err.message;\n'
              '          }\n'
              '        }\n'
              '      } else if (e is ServerError) {\n'
              '        if (e.code == \'AUTH_CAPTCHA_REQUIRED\') {\n'
              '          setState(() => _isLoading = false);\n'
              '          final ok = await _checkAndHandleCaptcha();\n'
              '          if (ok) _register();\n'
              '          return;\n'
              '        }\n'
              '        msg = e.message;\n'
              '      }\n'
              '      _showError(msg);\n'
              '    } finally {\n'
              '      if (mounted) setState(() => _isLoading = false);\n'
              '    }\n'
              '  }\n'
              '\n'
              '  void _showError(String msg) {\n'
              '    ScaffoldMessenger.of(context).showSnackBar(SnackBar(content: Text(msg)));\n'
              '  }\n'
              '\n'
              '  bool _isInvitationCode(String value) {\n'
              '    return RegExp(r\'^[0-9A-Fa-f]{12,}$\').hasMatch(value.trim());\n'
              '  }\n'
              '\n'
              '  bool _isCaptchaError(Object e) {\n'
              '    if (e is ServerError) {\n'
              '      final code = e.code.toUpperCase();\n'
              '      final message = e.message.toLowerCase();\n'
              '      return code == \'AUTH_CAPTCHA_REQUIRED\' ||\n'
              '          code == \'AUTH_CAPTCHA_INVALID\' ||\n'
              '          message.contains(\'captcha\') ||\n'
              '          message.contains(\'图形验证码\') ||\n'
              '          message.contains(\'安全验证\');\n'
              '    }\n'
              '    final text = e.toString().toLowerCase();\n'
              '    return text.contains(\'auth_captcha_required\') ||\n'
              '        text.contains(\'auth_captcha_invalid\') ||\n'
              '        text.contains(\'captcha verification is required\') ||\n'
              '        text.contains(\'captcha\') ||\n'
              '        text.contains(\'图形验证码\') ||\n'
              '        text.contains(\'安全验证\');\n'
              '  }\n'
              '\n'
              '  String _currentLoginType() {\n'
              '    return switch (_idMode) {\n'
              '      _IdMode.mobile => \'mobile\',\n'
              '      _IdMode.email => \'email\',\n'
              '    };\n'
              '  }\n'
              '\n'
              '  // ── Build ──────────────────────────────────────────────────────────────────\n'
              '\n'
              '  @override\n'
              '  Widget build(BuildContext context) {\n'
              '    ref.listen<AsyncValue<AuthState>>(authProvider, (_, next) {\n'
              '      next.whenOrNull(\n'
              '        data: (s) {\n'
              '          if (s.status == AuthStatus.authenticated) {\n'
              '            context.go(AppRoutes.home);\n'
              '            return;\n'
              '          }\n'
              '          if (authStateNeedsSpaceSelection(s)) {\n'
              '            context.go(AppRoutes.tenantSelect);\n'
              '          }\n'
              '        },\n'
              '        error: (e, _) {\n'
              '          if (_isCaptchaError(e)) return;\n'
              '          if (e is ServerError) {\n'
              '            _showError(e.message);\n'
              '          } else if (e is AuthError) {\n'
              '            _showError(\'微界号或密码错误\');\n'
              '          } else if (e is NetworkError) {\n'
              '            _showError(e.message);\n'
              '          } else {\n'
              '            _showError(e.toString());\n'
              '          }\n'
              '        },\n'
              '      );\n'
              '    });\n'
              '\n'
              '    return Scaffold(\n'
              '      backgroundColor: Theme.of(context).scaffoldBackgroundColor,\n'
              '      appBar: AppBar(\n'
              '        backgroundColor: Theme.of(context).scaffoldBackgroundColor,\n'
              '        elevation: 0,\n'
              '        leading: IconButton(\n'
              '          icon: const Icon(Icons.arrow_back_ios, size: 20, color: _txtMain),\n'
              '          onPressed: () => Navigator.of(context).pop(),\n'
              '        ),\n'
              '        title: const Text(\'注册\',\n'
              '            style: TextStyle(\n'
              '                fontSize: 17, fontWeight: FontWeight.w600, color: _txtMain)),\n'
              '      ),\n'
              '      body: SafeArea(\n'
              '        child: SingleChildScrollView(\n'
              '          padding: const EdgeInsets.symmetric(horizontal: 24),\n'
              '          child: Column(\n'
              '            crossAxisAlignment: CrossAxisAlignment.start,\n'
              '            children: [\n'
              '              const SizedBox(height: 8),\n'
              '              // 昵称\n'
              '              _buildLabel(\'昵称\'),\n'
              '              _buildInput(controller: _displayNameCtrl, hint: \'设置昵称\'),\n'
              '              const SizedBox(height: 16),\n'
              '\n'
              '              // 手机/邮箱切换（始终显示）\n'
              '              _buildIdModeTabs(),\n'
              '              const SizedBox(height: 8),\n'
              '\n'
              '              // 手机号或邮箱输入\n'
              '              if (_idMode == _IdMode.mobile) ...[\n'
              '                _buildLabel(\'手机号\'),\n'
              '                _buildPhoneInput(),\n'
              '              ] else ...[\n'
              '                _buildLabel(\'邮箱\'),\n'
              '                _buildInput(\n'
              '                  controller: _identifierCtrl,\n'
              '                  hint: \'请输入邮箱\',\n'
              '                  keyboardType: TextInputType.emailAddress,\n'
              '                ),\n'
              '              ],\n'
              '              const SizedBox(height: 16),\n'
              '\n'
              '              // 验证码（按需显示）\n'
              '              if (_verificationRequired) ...[\n'
              '                _buildLabel(\'验证码\'),\n'
              '                _buildCodeRow(),\n'
              '                const SizedBox(height: 16),\n'
              '              ],\n'
              '\n'
              '              // 密码\n'
              '              _buildLabel(\'密码\'),\n'
              '              _buildInput(\n'
              '                controller: _passwordCtrl,\n'
              '                hint: \'设置密码（至少6位）\',\n'
              '                obscure: _obscurePassword,\n'
              '                suffix: _eyeBtn(_obscurePassword,\n'
              '                    () => setState(() => _obscurePassword = !_obscurePassword)),\n'
              '              ),\n'
              '              const SizedBox(height: 16),\n'
              '              _buildLabel(\'确认密码\'),\n'
              '              _buildInput(\n'
              '                controller: _confirmCtrl,\n'
              '                hint: \'再次输入密码\',\n'
              '                obscure: _obscureConfirm,\n'
              '                suffix: _eyeBtn(_obscureConfirm,\n'
              '                    () => setState(() => _obscureConfirm = !_obscureConfirm)),\n'
              '              ),\n'
              '              const SizedBox(height: 20),\n'
              '\n'
              '              // 企业ID/邀请码（可选，折叠）\n'
              '              _buildEnterpriseSection(),\n'
              '              const SizedBox(height: 20),\n'
              '\n'
              '              // 协议\n'
              '              Row(crossAxisAlignment: CrossAxisAlignment.start, children: [\n'
              '                SizedBox(\n'
              '                  width: 20,\n'
              '                  height: 20,\n'
              '                  child: Checkbox(\n'
              '                    value: _agreedToTerms,\n'
              '                    onChanged: (v) =>\n'
              '                        setState(() => _agreedToTerms = v ?? false),\n'
              '                    activeColor: _primary,\n'
              '                    materialTapTargetSize: MaterialTapTargetSize.shrinkWrap,\n'
              '                    shape: RoundedRectangleBorder(\n'
              '                        borderRadius: BorderRadius.circular(3)),\n'
              '                  ),\n'
              '                ),\n'
              '                const SizedBox(width: 8),\n'
              '                const Expanded(\n'
              '                  child: Text(\'我已阅读并同意《用户协议》和《隐私政策》\',\n'
              '                      style: TextStyle(fontSize: 13, color: _txtGray)),\n'
              '                ),\n'
              '              ]),\n'
              '              const SizedBox(height: 24),\n'
              '\n'
              '              // 注册按钮\n'
              '              SizedBox(\n'
              '                width: double.infinity,\n'
              '                height: 48,\n'
              '                child: ElevatedButton(\n'
              '                  onPressed: (_agreedToTerms && !_isLoading) ? _register : null,\n'
              '                  style: ElevatedButton.styleFrom(\n'
              '                    backgroundColor:\n'
              '                        _agreedToTerms ? _primary : const Color(0xFFCCCCCC),\n'
              '                    foregroundColor: Colors.white,\n'
              '                    elevation: 0,\n'
              '                    shape: RoundedRectangleBorder(\n'
              '                        borderRadius: BorderRadius.circular(8)),\n'
              '                  ),\n'
              '                  child: _isLoading\n'
              '                      ? SizedBox(\n'
              '                          width: 20,\n'
              '                          height: 20,\n'
              '                          child: CircularProgressIndicator(\n'
              '                              strokeWidth: 2,\n'
              '                              color: Theme.of(context).colorScheme.surface))\n'
              '                      : const Text(\'注册并登录\',\n'
              '                          style: TextStyle(\n'
              '                              fontSize: 16, fontWeight: FontWeight.w600)),\n'
              '                ),\n'
              '              ),\n'
              '              const SizedBox(height: 16),\n'
              '\n'
              '              // 去登录\n'
              '              Center(\n'
              '                child: GestureDetector(\n'
              '                  onTap: () => Navigator.of(context).pop(),\n'
              '                  child: const Text.rich(TextSpan(\n'
              '                    text: \'已有微界号？\',\n'
              '                    style: TextStyle(fontSize: 14, color: _txtGray),\n'
              '                    children: [\n'
              '                      TextSpan(\n'
              '                          text: \'去登录\',\n'
              '                          style: TextStyle(\n'
              '                              color: _primary, fontWeight: FontWeight.w500)),\n'
              '                    ],\n'
              '                  )),\n'
              '                ),\n'
              '              ),\n'
              '              const SizedBox(height: 32),\n'
              '            ],\n'
              '          ),\n'
              '        ),\n'
              '      ),\n'
              '    );\n'
              '  }\n'
              '\n'
              '  // ── 手机/邮箱切换 Tab ─────────────────────────────────────────────────────\n'
              '\n'
              '  Widget _buildIdModeTabs() {\n'
              '    return Row(children: [\n'
              '      if (_emailEnabled) ...[\n'
              '        _idTab(\'邮箱\', _IdMode.email),\n'
              '        const SizedBox(width: 16),\n'
              '      ],\n'
              '      if (_smsEnabled) ...[\n'
              '        _idTab(\'手机号\', _IdMode.mobile),\n'
              '        const SizedBox(width: 16),\n'
              '      ],\n'
              '    ]);\n'
              '  }\n'
              '\n'
              '  Widget _idTab(String label, _IdMode mode) {\n'
              '    final selected = _idMode == mode;\n'
              '    return GestureDetector(\n'
              '      onTap: () {\n'
              '        if (_idMode == mode) return;\n'
              '        setState(() {\n'
              '          _idMode = mode;\n'
              '          _identifierCtrl.clear();\n'
              '          _codeCtrl.clear();\n'
              '          _countdown = 0;\n'
              '          _countdownTimer?.cancel();\n'
              '        });\n'
              '        _refreshVerificationRequired();\n'
              '      },\n'
              '      child: Container(\n'
              '        padding: const EdgeInsets.symmetric(vertical: 6),\n'
              '        decoration: BoxDecoration(\n'
              '            border: Border(\n'
              '                bottom: BorderSide(\n'
              '                    color: selected ? _primary : Colors.transparent,\n'
              '                    width: 2))),\n'
              '        child: Text(label,\n'
              '            style: TextStyle(\n'
              '              fontSize: 14,\n'
              '              fontWeight: selected ? FontWeight.w600 : FontWeight.w400,\n'
              '              color: selected ? _primary : _txtGray,\n'
              '            )),\n'
