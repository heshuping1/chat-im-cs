{
  "name": "lpp-pc-client",
  "version": "0.1.0",
  "private": true,
  "description": "LPP Windows customer service desktop client",
  "main": "dist/main/main.js",
  "type": "module",
  "scripts": {
    "dev:browser": "vite --host 127.0.0.1",
    "dev": "npm run build:electron && concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build:electron": "tsc -p tsconfig.electron.json",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "build": "tsc --noEmit && vite build && tsc -p tsconfig.electron.json",
    "test:unit": "vitest run tests/unit",
    "test:browser": "playwright test",
    "test:full": "npm run typecheck && npm run build && npm run test:browser",
    "start": "electron .",
    "dist:win": "npm run build && electron-builder --win nsis"
  },
  "dependencies": {
    "@lexical/history": "^0.44.0",
    "@lexical/react": "^0.44.0",
    "@lexical/rich-text": "^0.44.0",
    "@lexical/selection": "^0.44.0",
    "@lexical/utils": "^0.44.0",
    "@microsoft/signalr": "^8.0.17",
    "@tanstack/react-query": "^5.85.5",
    "lexical": "^0.44.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^4.1.7",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.lpp.pcclient",
    "productName": "LPP 客服客户端",
    "icon": "assets/app-icon-green-bubble.ico",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets/app-icon-green-bubble.ico",
        "to": "app-icon.ico"
      }
    ],
    "win": {
      "icon": "assets/app-icon-green-bubble.ico",
      "target": "nsis",
      "artifactName": "LPP-CustomerService-${version}.${ext}"
    },
    "nsis": {
      "installerIcon": "assets/app-icon-green-bubble.ico",
      "uninstallerIcon": "assets/app-icon-green-bubble.ico",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
